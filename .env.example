GITHUB_ORG=exevio
GITHUB_TOKEN=github_pat_or_classic_token_here

# Fine-grained PAT: Organization Administration permission set to Read-only.
# Classic PAT: include admin:org. read:org alone is not enough for org billing usage endpoints.

# Optional. Use when the organization is billed through an enterprise account.
# Example: if the org-level AI credit endpoint returns 404, set the enterprise slug here.
# GITHUB_ENTERPRISE=your-enterprise-slug

# Optional. Use this to match the denominator shown in GitHub's Included credits widget exactly.
INCLUDED_CREDITS_OVERRIDE=33000

PORT=8787
REFRESH_INTERVAL_MS=900000
GITHUB_API_VERSION=2026-03-10